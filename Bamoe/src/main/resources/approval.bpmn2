    <bpmn2:userTask id="checkerTask" name="Checker">
      <bpmn2:incoming>flow_maker_checker</bpmn2:incoming>
      <bpmn2:outgoing>flow_checker_gw</bpmn2:outgoing>
      <bpmn2:ioSpecification id="_427B61E8-E5BB-4628-8AEF-F792180DC050">
        <bpmn2:dataInput id="_71DCAAE6-1479-41B5-9096-197EF98661A0" name="TaskName" drools:dtype="" />
        <bpmn2:dataInput id="_68AACD52-EF0A-4FE3-9828-37F8F5EF9852" name="request" drools:dtype="" />
