<?xml version="1.0" encoding="UTF-8" ?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:drools="http://www.jboss.org/drools" id="_approval-definitions" targetNamespace="http://www.omg.org/bpmn20" exporter="jBPM" exporterVersion="9.4">
  <bpmn2:itemDefinition id="_StringItem" structureRef="String" />
  <bpmn2:process id="approval" name="Maker Checker Approval" isExecutable="true" processType="Public">
    <bpmn2:property id="makerActors" name="makerActors" itemSubjectRef="_StringItem" />
    <bpmn2:property id="request" name="request" itemSubjectRef="_StringItem" />
    <bpmn2:property id="makerComment" name="makerComment" itemSubjectRef="_StringItem" />
    <bpmn2:property id="checkerDecision" name="checkerDecision" itemSubjectRef="_StringItem" />
    <bpmn2:property id="checkerComment" name="checkerComment" itemSubjectRef="_StringItem" />
    <bpmn2:startEvent id="start" name="Start">
      <bpmn2:outgoing>flow_start_merge</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:endEvent id="approvedEnd" name="Approved">
      <bpmn2:incoming>flow_approve</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:endEvent id="rejectedEnd" name="Rejected">
      <bpmn2:incoming>flow_reject</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:exclusiveGateway id="mergeGateway" name="Merge" gatewayDirection="Converging">
      <bpmn2:incoming>flow_start_merge</bpmn2:incoming>
      <bpmn2:incoming>flow_sendback</bpmn2:incoming>
      <bpmn2:outgoing>flow_merge_maker</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="decisionGateway" name="Decision" gatewayDirection="Diverging" default="flow_sendback">
      <bpmn2:incoming>flow_checker_gw</bpmn2:incoming>
      <bpmn2:outgoing>flow_approve</bpmn2:outgoing>
      <bpmn2:outgoing>flow_reject</bpmn2:outgoing>
      <bpmn2:outgoing>flow_sendback</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:userTask id="makerTask" name="Maker">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue>Maker</drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>flow_merge_maker</bpmn2:incoming>
      <bpmn2:outgoing>flow_maker_checker</bpmn2:outgoing>
      <bpmn2:ioSpecification id="_B8030A65-509C-4357-8B58-148B083BB195">
        <bpmn2:dataInput id="_AB66F941-4529-47AF-A8D1-E9FC8A281D89" name="TaskName" drools:dtype="" />
        <bpmn2:dataInput id="_99C39F7E-47D1-4CF5-A215-7DEC4C0CEA08" name="GroupId" drools:dtype="String" itemSubjectRef="_StringItem" />
        <bpmn2:dataOutput name="request" id="_0550C962-FDCD-4461-9218-9DE34B9C7A59" drools:dtype="" />
        <bpmn2:dataOutput name="makerComment" id="_8439A722-6EA1-4B2A-8FD0-7A5AB41D702B" drools:dtype="" />
        <bpmn2:inputSet id="_3AFBABB3-51FD-41FF-B628-E1E2CBB9D2D1">
          <bpmn2:dataInputRefs>_AB66F941-4529-47AF-A8D1-E9FC8A281D89</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>_99C39F7E-47D1-4CF5-A215-7DEC4C0CEA08</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet id="_D2F2B1E8-880B-4E2D-AFDE-308B140F6586">
          <bpmn2:dataOutputRefs>_0550C962-FDCD-4461-9218-9DE34B9C7A59</bpmn2:dataOutputRefs>
          <bpmn2:dataOutputRefs>_8439A722-6EA1-4B2A-8FD0-7A5AB41D702B</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation id="_D61EF68F-1C8C-4C20-AAEB-B7E92FE0D703">
        <bpmn2:targetRef>_AB66F941-4529-47AF-A8D1-E9FC8A281D89</bpmn2:targetRef>
        <bpmn2:assignment id="_2326E267-79E6-4FDB-9FB9-636242603564">
          <bpmn2:from id="_13977F5F-2CAF-4121-85C1-8ACCE13BA081" xsi:type="tFormalExpression">Maker</bpmn2:from>
          <bpmn2:to id="_77B7131C-B86C-4D57-9F66-3B4B0AF7AEE2">_AB66F941-4529-47AF-A8D1-E9FC8A281D89</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation id="_0135F9BC-C5D5-4175-8C90-0571ACA4428F">
        <bpmn2:targetRef>_99C39F7E-47D1-4CF5-A215-7DEC4C0CEA08</bpmn2:targetRef>
        <bpmn2:assignment id="_B38A639A-12F7-4CD9-B087-1E54166B5033">
          <bpmn2:from id="_5E6637D8-E4ED-4377-9F35-9D40721676D2" xsi:type="tFormalExpression">#{makerActors}</bpmn2:from>
          <bpmn2:to id="_C2F2D6CC-7E4D-473B-8F28-16A7FE188395">_99C39F7E-47D1-4CF5-A215-7DEC4C0CEA08</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation id="_96B8EBD9-7A23-4AC3-9E81-137B3BA50576">
        <bpmn2:sourceRef>_0550C962-FDCD-4461-9218-9DE34B9C7A59</bpmn2:sourceRef>
        <bpmn2:targetRef>request</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation id="_58D50384-3771-4F3A-8618-81E12D161F6B">
        <bpmn2:sourceRef>_8439A722-6EA1-4B2A-8FD0-7A5AB41D702B</bpmn2:sourceRef>
        <bpmn2:targetRef>makerComment</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:userTask id="checkerTask" name="Checker">
      <bpmn2:incoming>flow_maker_checker</bpmn2:incoming>
      <bpmn2:outgoing>flow_checker_gw</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="checkerTask_taskName" name="TaskName" />
        <bpmn2:dataInput id="checkerTask_groupId" name="GroupId" />
        <bpmn2:dataInput id="checkerTask_request" name="request" />
        <bpmn2:dataInput id="checkerTask_makerComment" name="makerComment" />
        <bpmn2:dataOutput id="checkerTask_decision" name="checkerDecision" />
        <bpmn2:dataOutput id="checkerTask_comment" name="checkerComment" />
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>checkerTask_taskName</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>checkerTask_groupId</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>checkerTask_request</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>checkerTask_makerComment</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>checkerTask_decision</bpmn2:dataOutputRefs>
          <bpmn2:dataOutputRefs>checkerTask_comment</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>checkerTask_taskName</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">Checker</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">checkerTask_taskName</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>checkerTask_groupId</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">checkers</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">checkerTask_groupId</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>request</bpmn2:sourceRef>
        <bpmn2:targetRef>checkerTask_request</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>makerComment</bpmn2:sourceRef>
        <bpmn2:targetRef>checkerTask_makerComment</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>checkerTask_decision</bpmn2:sourceRef>
        <bpmn2:targetRef>checkerDecision</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>checkerTask_comment</bpmn2:sourceRef>
        <bpmn2:targetRef>checkerComment</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>
    <bpmn2:sequenceFlow id="flow_start_merge" sourceRef="start" targetRef="mergeGateway" />
    <bpmn2:sequenceFlow id="flow_merge_maker" sourceRef="mergeGateway" targetRef="makerTask" />
    <bpmn2:sequenceFlow id="flow_maker_checker" sourceRef="makerTask" targetRef="checkerTask" />
    <bpmn2:sequenceFlow id="flow_checker_gw" sourceRef="checkerTask" targetRef="decisionGateway" />
    <bpmn2:sequenceFlow id="flow_approve" sourceRef="decisionGateway" targetRef="approvedEnd">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return checkerDecision != null &amp;&amp; checkerDecision.equalsIgnoreCase(&quot;APPROVE&quot;);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="flow_reject" sourceRef="decisionGateway" targetRef="rejectedEnd">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return checkerDecision != null &amp;&amp; checkerDecision.equalsIgnoreCase(&quot;REJECT&quot;);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="flow_sendback" sourceRef="decisionGateway" targetRef="mergeGateway" />
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_approval">
    <bpmndi:BPMNPlane id="BPMNPlane_approval" bpmnElement="approval">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="100" y="106" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_mergeGateway" bpmnElement="mergeGateway" isMarkerVisible="true">
        <dc:Bounds x="190" y="99" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_makerTask" bpmnElement="makerTask">
        <dc:Bounds x="290" y="84" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_checkerTask" bpmnElement="checkerTask">
        <dc:Bounds x="440" y="84" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_decisionGateway" bpmnElement="decisionGateway" isMarkerVisible="true">
        <dc:Bounds x="590" y="99" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_approvedEnd" bpmnElement="approvedEnd">
        <dc:Bounds x="720" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_rejectedEnd" bpmnElement="rejectedEnd">
        <dc:Bounds x="720" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_flow_start_merge" bpmnElement="flow_start_merge">
        <di:waypoint x="136" y="124" />
        <di:waypoint x="190" y="124" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_merge_maker" bpmnElement="flow_merge_maker">
        <di:waypoint x="240" y="124" />
        <di:waypoint x="290" y="124" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_maker_checker" bpmnElement="flow_maker_checker">
        <di:waypoint x="390" y="124" />
        <di:waypoint x="440" y="124" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_checker_gw" bpmnElement="flow_checker_gw">
        <di:waypoint x="540" y="124" />
        <di:waypoint x="590" y="124" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_approve" bpmnElement="flow_approve">
        <di:waypoint x="640" y="124" />
        <di:waypoint x="720" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_reject" bpmnElement="flow_reject">
        <di:waypoint x="615" y="149" />
        <di:waypoint x="630" y="250" />
        <di:waypoint x="720" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_sendback" bpmnElement="flow_sendback">
        <di:waypoint x="615" y="99" />
        <di:waypoint x="630" y="40" />
        <di:waypoint x="230" y="40" />
        <di:waypoint x="215" y="99" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
